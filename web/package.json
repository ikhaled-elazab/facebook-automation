{
  "name": "fb-control-ui",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Local-only admin dashboard for the facebook-automation control plane. Built to static assets served same-origin by the Express control plane. Dev-only deps — never runs on the VPS.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@fontsource/hanken-grotesk": "^5.2.5",
    "@fontsource/jetbrains-mono": "^5.2.5",
    "@types/node": "^22.10.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitejs/plugin-react": "^4.4.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^15.14.0",
    "typescript": "^5.7.0",
    "vite": "^6.3.0"
  }
}
