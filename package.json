{
  "name": "facebook-automation",
  "version": "1.0.0",
  "description": "Facebook Page monitor bot with auto Like, Comment, Share",
  "main": "index.js",
  "scripts": {
    "proxy:check": "node proxyCheck.js",
    "login": "node login.js",
    "login:all": "node login.js --all",
    "login:manual": "node login.js --manual",
    "start": "node index.js",
    "control": "node server/index.js",
    "ui:install": "npm --prefix web install",
    "ui:dev": "npm --prefix web run dev",
    "ui:build": "npm --prefix web run build",
    "ui:lint": "npm --prefix web run lint",
    "ui:typecheck": "npm --prefix web run typecheck",
    "set-password": "node server/set-password.js",
    "migrate": "node migrate.js",
    "migrate:dry": "node migrate.js --dry-run",
    "healthcheck": "node scripts/healthcheck.js",
    "probe:errors": "node scripts/error-rate.js",
    "probe:ops": "node scripts/ops-probe.js",
    "pm2:start": "pm2 start pm2.config.js",
    "pm2:reload": "pm2 reload pm2.config.js",
    "test": "node --test \"test/**/*.test.js\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^11.10.0",
    "better-sqlite3-session-store": "^0.1.0",
    "cookie-parser": "^1.4.7",
    "csrf-csrf": "^4.0.3",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.19.0",
    "helmet": "^8.2.0",
    "openai": "^4.52.0",
    "playwright": "^1.44.0",
    "playwright-extra": "^4.3.6",
    "pm2": "^7.0.1",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "prettier": "^3.8.4"
  }
}
